<!doctype html>
<html><head><meta charset="utf-8"><style>{{ css|safe }}</style></head>
<body>
  <div class="title-card" style="--bg:{{ bg }};--text:{{ text }};--muted:{{ muted }};--accent:{{ accent }};">
    {% if motif_uri %}<div class="motif" style="background-image:url({{ motif_uri|safe }});"></div>
    <div class="scrim"></div>{% endif %}
    <div class="title-content">
      <div class="label">{{ account_name }}</div>
      <div class="title-headline">{{ heading }}</div>
      <div class="accent-rule"></div>
      <div class="title-source">{{ footer }}</div>
    </div>
  </div>
</body></html>
