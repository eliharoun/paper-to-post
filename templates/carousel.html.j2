<!doctype html>
<html><head><meta charset="utf-8"><style>{{ css|safe }}</style></head>
<body>
  <div class="card" style="--bg:{{ bg }};--text:{{ text }};--muted:{{ muted }};--accent:{{ accent }};--fs-heading:{{ fs_heading }}px;--fs-body:{{ fs_body }}px;--fs-label:{{ fs_label }}px;--fs-footer:{{ fs_footer }}px;">
    <div class="label">{{ account_name }}</div>
    <div class="accent-rule"></div>
    <div class="heading">{{ heading }}</div>
    <div class="body">{{ body }}</div>
    <div class="footer">{{ footer }}</div>
  </div>
</body></html>
