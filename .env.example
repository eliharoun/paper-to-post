# Copy to .env and fill in. Everything here is optional except CONTACT_EMAIL,
# which the polite API pools want. Never commit your real .env.

# --- Contact (used as the mailto in API User-Agents) -------------------------
# Required by polite pools (PubMed E-utilities, Crossref, OpenAlex, and the
# Unpaywall OA-PDF lookup). MUST be a real address — Unpaywall rejects
# example.com / placeholders with HTTP 422, which disables OA screenshots.
CONTACT_EMAIL=

# --- Paper API keys (optional; improve rate limits / results) ----------------
SEMANTIC_SCHOLAR_API_KEY=
NCBI_API_KEY=
# OpenAlex has no API key — it identifies you by email. Defaults to CONTACT_EMAIL.
OPENALEX_MAILTO=

# --- Reddit trend signal (optional) ------------------------------------------
# Powers the "reddit" trend signal. Create a free "script" app at
# https://www.reddit.com/prefs/apps to get these. If unset, the reddit signal
# is skipped automatically (the run still succeeds, just without Reddit heat).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Reddit rate-limits generic User-Agents. Set a unique one in Reddit's format
# (defaults to python:paper-to-post:0.1 (by /u/paper-to-post) if unset). Can
# also be set per-signal via the signal's params.user_agent in topics.yml.
REDDIT_USER_AGENT=

# --- Fetch / render toggles (read by the scripts) ----------------------------
# Full paper text extraction (falls back to abstract when off or unavailable).
ENABLE_FULL_TEXT=true
# Paper first-page screenshot card (arXiv / open-access only).
ENABLE_PAPER_SCREENSHOT=true
PDF_MAX_BYTES=52428800
PDF_FETCH_TIMEOUT_SECONDS=30

# --- Selection knobs (advisory: honored by the skill's judgment, not scripts) -
MIN_SCORE_TO_POST=70
PAPER_LOOKBACK_HOURS=48
MAX_CANDIDATES_PER_RUN=80
MAX_LLM_SCORED_CANDIDATES=25

# --- Storage ------------------------------------------------------------------
DATA_DIR=data
OUTPUT_DIR=outputs

# --- Hero image generation (front card) --------------------------------------
# Google Gemini API key for generating the front-card hero image. Requires
# billing enabled (Gemini image generation has no free tier). If unset, the
# front card falls back to the branded motif backdrop.
GOOGLE_API_KEY=

# Minimum WCAG contrast ratio the headline + account label must have against the
# imagery behind them, or research-hero rejects the hero and falls back to the
# motif front card. Default 1.7. Raise for stricter legibility, lower if good
# heroes are being rejected too often.
HERO_MIN_TEXT_CONTRAST=1.7

# --- Optional Telegram push (legacy; the default delivery is Instagram) -------
# `research-notify` can also push a finished bundle to a Telegram bot. Use one
# bot PER account. Set the generic pair to whichever account you're delivering
# (or keep per-account pairs and export them before the call).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
